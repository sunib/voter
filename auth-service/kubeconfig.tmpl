# kubectl access for the voter demo
# Token expires: {{ .ExpiresAt }} (~10 min from issue)
#
# Quick commands:
#   kubectl get quizsessions.examples.configbutler.ai -n {{ .Namespace }}
#   kubectl get quizsubmissions.examples.configbutler.ai -n {{ .Namespace }}
apiVersion: v1
kind: Config
clusters:
- name: voter
  cluster:
    server: {{ .ServerURL }}
    insecure-skip-tls-verify: true
users:
- name: audience
  user:
    token: {{ .Token }}
contexts:
- name: voter
  context:
    cluster: voter
    user: audience
    namespace: {{ .Namespace }}
current-context: voter
